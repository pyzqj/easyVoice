{
  "name": "easy-voice",
  "version": "0.0.15",
  "private": true,
  "scripts": {
    "build": "pnpm -r build && mkdir -p build && cp -r packages/backend/public/* build/",
    "dev": "pnpm -r dev",
    "start": "pnpm --filter backend start",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.15.4",
  "workspaces": [
    "packages/*"
  ]
}
