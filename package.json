{
  "name": "easy-voice",
  "version": "0.0.15",
  "private": true,
  "scripts": {
    "build": "pnpm -r build && mkdir -p build && cp -r packages/backend/public/* build/",
    "dev": "pnpm -r dev",
    "start": "pnpm --filter backend start",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "build:node-functions": "mkdir -p node-functions && cp -r packages/backend/src/* node-functions/"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "express-rate-limit": "^7.5.0",
    "connect-history-api-fallback": "^2.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.15.4",
  "workspaces": [
    "packages/*"
  ]
}
